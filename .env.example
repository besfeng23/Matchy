# Public app configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_server_only_service_role_key
DATABASE_URL=postgresql://user:password@localhost:5432/matchy

# Yoursafe payments
YOURSAFE_API_KEY=replace_with_server_only_yoursafe_api_key
YOURSAFE_WEBHOOK_SECRET=replace_with_server_only_yoursafe_webhook_secret

# SMTP transactional email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace_with_smtp_username
SMTP_PASSWORD=replace_with_server_only_smtp_password
SMTP_FROM="Matchy <no-reply@example.com>"

# Pandora memory
PANDORA_BASE_URL=https://pandorasmemory.example.com
PANDORA_INTERNAL_TOKEN=replace_with_server_only_pandora_token
PANDORA_NAMESPACE=matchy_alpha

# Runtime
NODE_ENV=development
